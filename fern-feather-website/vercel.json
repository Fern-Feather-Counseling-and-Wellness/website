{
  "version": 2,
  "name": "fern-feather-wellness",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/services",
      "dest": "/services.html"
    },
    {
      "src": "/nicole",
      "dest": "/nicole.html"
    },
    {
      "src": "/kiera",
      "dest": "/kiera.html"
    },
    {
      "src": "/resources",
      "dest": "/resources.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
